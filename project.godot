[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Capy Dungeon"
config/description="Tap-combo capybara battler"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="res://assets/splash.png"
config/icon="res://assets/icon.png"

[autoload]

PurchaseStore="*res://scripts/PurchaseStore.gd"
SkillMgr="*res://scripts/SkillManager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[dotnet]

project/assembly_name="Capy Dungeon"

[editor_plugins]

enabled=PackedStringArray("res://addons/GodotGooglePlayBilling/plugin.cfg")

